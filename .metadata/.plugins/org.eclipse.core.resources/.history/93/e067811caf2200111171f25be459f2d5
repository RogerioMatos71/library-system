package application;

import java.util.Scanner;

import entities.Library;
import entities.User;
import util.InputUtils;

public class Program {

	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);
		int option;
		
		
		
		do {
			
			InputUtils.showMenu();
		
		option = sc.nextInt();
		
		switch (option) {
		case 1:
			
			InputUtils.enterData();
			
		    break;
		
		case 2:
			System.out.println("Enter the name to consult: ");
			sc.nextLine();
			String name2 = sc.nextLine();
			String result = library.consultUser(name2);
			
			System.out.print(result);
		    break;
		    
		case 3:
			System.out.print("Enter the name to delete: ");
			sc.nextLine();
			String name3 = sc.nextLine();
			 System.out.print("Enter user CPF: ");
			    String CPF2 = sc.nextLine();
			    System.out.print("Enter user register: ");
			    Integer registration2 = sc.nextInt();
			
			User user2 = new User(name3, CPF2, registration2);
			
			library.removeUser(user2);
			
			
			
			
		}
		
		
		
		}
		while (option != 0);
	
		
		
		
		
		
		
		
		sc.close();
		
	
		
	}
	
	
}
